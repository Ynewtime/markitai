{
  "$defs": {
    "BatchConfig": {
      "description": "Batch processing configuration.",
      "properties": {
        "concurrency": {
          "default": 10,
          "description": "Max parallel file processing tasks",
          "minimum": 1,
          "title": "Concurrency",
          "type": "integer"
        },
        "url_concurrency": {
          "default": 5,
          "description": "Max parallel URL fetches",
          "minimum": 1,
          "title": "Url Concurrency",
          "type": "integer"
        },
        "state_flush_interval_seconds": {
          "default": 10,
          "description": "Seconds between state file writes",
          "title": "State Flush Interval Seconds",
          "type": "integer"
        },
        "scan_max_depth": {
          "default": 5,
          "description": "Max directory recursion depth",
          "minimum": 0,
          "title": "Scan Max Depth",
          "type": "integer"
        },
        "scan_max_files": {
          "default": 10000,
          "description": "Max files to scan per directory",
          "minimum": 1,
          "title": "Scan Max Files",
          "type": "integer"
        },
        "heavy_task_limit": {
          "default": 0,
          "description": "Max heavy tasks (0=unlimited)",
          "minimum": 0,
          "title": "Heavy Task Limit",
          "type": "integer"
        }
      },
      "title": "BatchConfig",
      "type": "object"
    },
    "CacheConfig": {
      "description": "Cache configuration.",
      "properties": {
        "enabled": {
          "default": true,
          "title": "Enabled",
          "type": "boolean"
        },
        "no_cache": {
          "default": false,
          "description": "Skip reading cache, still write",
          "title": "No Cache",
          "type": "boolean"
        },
        "no_cache_patterns": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "No Cache Patterns",
          "type": "array"
        },
        "max_size_bytes": {
          "default": 536870912,
          "description": "Max cache size in bytes",
          "title": "Max Size Bytes",
          "type": "integer"
        },
        "global_dir": {
          "default": "~/.markitai",
          "description": "Global cache/config directory",
          "title": "Global Dir",
          "type": "string"
        }
      },
      "title": "CacheConfig",
      "type": "object"
    },
    "CloudflareConfig": {
      "description": "Cloudflare Browser Rendering + Workers AI configuration.\n\nUsed as a cloud-based fallback for URL fetching (Browser Rendering /markdown API)\nand file conversion (Workers AI toMarkdown API). Requires a Cloudflare account\nwith Browser Rendering enabled (available on Free plan).\n\nBoth api_token and account_id support env: syntax for environment variable resolution.",
      "properties": {
        "api_token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "CF API token (supports env: syntax)",
          "title": "Api Token"
        },
        "account_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "CF account ID (supports env: syntax)",
          "title": "Account Id"
        },
        "timeout": {
          "default": 30000,
          "description": "Browser rendering timeout (ms)",
          "title": "Timeout",
          "type": "integer"
        },
        "wait_until": {
          "default": "networkidle0",
          "description": "Page load event to wait for",
          "title": "Wait Until",
          "type": "string"
        },
        "cache_ttl": {
          "default": 0,
          "description": "Browser rendering cache TTL (seconds)",
          "title": "Cache Ttl",
          "type": "integer"
        },
        "reject_resource_patterns": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reject Resource Patterns"
        },
        "user_agent": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Custom User-Agent string",
          "title": "User Agent"
        },
        "cookies": {
          "anyOf": [
            {
              "items": {
                "additionalProperties": {
                  "type": "string"
                },
                "type": "object"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cookies"
        },
        "wait_for_selector": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "CSS selector to wait for after load",
          "title": "Wait For Selector"
        },
        "http_credentials": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Http Credentials"
        },
        "convert_enabled": {
          "default": false,
          "description": "Use Workers AI for file conversion",
          "title": "Convert Enabled",
          "type": "boolean"
        }
      },
      "title": "CloudflareConfig",
      "type": "object"
    },
    "DefuddleConfig": {
      "description": "Defuddle content extraction API configuration.\n\nDefuddle (https://defuddle.md) extracts clean article content from web pages,\nremoving clutter like ads, sidebars, and navigation. Returns Markdown with\nrich YAML frontmatter (title, author, published, description, word_count).\n\nNOTE: Rate limit is undocumented. The default RPM is conservative.\nNOTE: JS rendering capability of the API is unconfirmed — SPA-heavy sites\nmay still need playwright as fallback.",
      "properties": {
        "timeout": {
          "default": 30,
          "description": "Request timeout in seconds",
          "title": "Timeout",
          "type": "integer"
        },
        "rpm": {
          "default": 20,
          "description": "Max requests per minute",
          "minimum": 1,
          "title": "Rpm",
          "type": "integer"
        }
      },
      "title": "DefuddleConfig",
      "type": "object"
    },
    "DomainProfileConfig": {
      "description": "Domain-specific overrides for fetch settings.",
      "properties": {
        "wait_for_selector": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Wait For Selector"
        },
        "wait_for": {
          "anyOf": [
            {
              "enum": [
                "load",
                "domcontentloaded",
                "networkidle"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Wait For"
        },
        "extra_wait_ms": {
          "anyOf": [
            {
              "maximum": 30000,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Extra Wait Ms"
        },
        "prefer_strategy": {
          "anyOf": [
            {
              "enum": [
                "static",
                "defuddle",
                "playwright",
                "jina",
                "cloudflare"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prefer Strategy"
        },
        "strategy_priority": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Custom strategy order for this domain. Overrides global and prefer_strategy.",
          "title": "Strategy Priority"
        },
        "skip_auto_scroll": {
          "default": false,
          "description": "Skip auto-scrolling for single-content pages (tweets, issues, docs).",
          "title": "Skip Auto Scroll",
          "type": "boolean"
        },
        "reject_resource_patterns": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "URL patterns to block during Playwright navigation (e.g. '**/analytics/**').",
          "title": "Reject Resource Patterns"
        }
      },
      "title": "DomainProfileConfig",
      "type": "object"
    },
    "FetchConfig": {
      "description": "URL fetch configuration for handling static and JS-rendered pages.",
      "properties": {
        "strategy": {
          "default": "auto",
          "description": "Default URL fetch strategy",
          "enum": [
            "auto",
            "static",
            "defuddle",
            "playwright",
            "jina",
            "cloudflare"
          ],
          "title": "Strategy",
          "type": "string"
        },
        "remote_consent": {
          "default": "always",
          "description": "Consent for sending URLs to remote extraction services (defuddle.md, Jina, Cloudflare) in the auto strategy chain, tried one at a time only after local strategies fail. Private/local/credentialed URLs never use remote services regardless of this setting. Public X/Twitter Playwright enrichment also uses the first-use disclosure. It does not open its own prompt under ask, but honors a cached process-wide decline, never, and the hard opt-out. always (default): use them without asking (a stderr notice discloses the first use); ask: prompt once per run on an interactive TTY, otherwise skip remote services; never: local strategies only. Overridden by the MARKITAI_NO_REMOTE_FETCH hard opt-out, including when an explicit remote strategy is selected.",
          "enum": [
            "ask",
            "always",
            "never"
          ],
          "title": "Remote Consent",
          "type": "string"
        },
        "defuddle": {
          "$ref": "#/$defs/DefuddleConfig"
        },
        "playwright": {
          "$ref": "#/$defs/PlaywrightConfig"
        },
        "jina": {
          "$ref": "#/$defs/JinaConfig"
        },
        "cloudflare": {
          "$ref": "#/$defs/CloudflareConfig"
        },
        "kreuzberg_convert_enabled": {
          "default": false,
          "description": "Force kreuzberg converter for all supported file formats.",
          "title": "Kreuzberg Convert Enabled",
          "type": "boolean"
        },
        "policy": {
          "$ref": "#/$defs/FetchPolicyConfig"
        },
        "domain_profiles": {
          "additionalProperties": {
            "$ref": "#/$defs/DomainProfileConfig"
          },
          "title": "Domain Profiles",
          "type": "object"
        },
        "fallback_patterns": {
          "items": {
            "type": "string"
          },
          "title": "Fallback Patterns",
          "type": "array"
        }
      },
      "title": "FetchConfig",
      "type": "object"
    },
    "FetchPolicyConfig": {
      "description": "Configuration for fetch strategy policy engine.",
      "properties": {
        "enabled": {
          "default": true,
          "title": "Enabled",
          "type": "boolean"
        },
        "max_strategy_hops": {
          "default": 5,
          "description": "Max strategy fallback attempts",
          "maximum": 6,
          "minimum": 1,
          "title": "Max Strategy Hops",
          "type": "integer"
        },
        "strategy_priority": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Custom global strategy order. Overrides the default priority.",
          "title": "Strategy Priority"
        },
        "local_only_patterns": {
          "description": "Domain/IP patterns that must use local-only strategies (NO_PROXY syntax).",
          "items": {
            "type": "string"
          },
          "title": "Local Only Patterns",
          "type": "array"
        },
        "inherit_no_proxy": {
          "default": true,
          "description": "Merge NO_PROXY env var into local_only_patterns at runtime.",
          "title": "Inherit No Proxy",
          "type": "boolean"
        }
      },
      "title": "FetchPolicyConfig",
      "type": "object"
    },
    "ImageConfig": {
      "description": "Image processing configuration.",
      "properties": {
        "alt_enabled": {
          "default": false,
          "description": "Generate alt text via LLM",
          "title": "Alt Enabled",
          "type": "boolean"
        },
        "desc_enabled": {
          "default": false,
          "description": "Generate description files via LLM",
          "title": "Desc Enabled",
          "type": "boolean"
        },
        "compress": {
          "default": true,
          "description": "Compress images before embedding",
          "title": "Compress",
          "type": "boolean"
        },
        "quality": {
          "default": 75,
          "description": "JPEG/WebP quality (1-100)",
          "maximum": 100,
          "minimum": 1,
          "title": "Quality",
          "type": "integer"
        },
        "format": {
          "default": "jpeg",
          "description": "Output image format",
          "enum": [
            "jpeg",
            "png",
            "webp"
          ],
          "title": "Format",
          "type": "string"
        },
        "max_width": {
          "default": 1920,
          "description": "Downscale images wider than this (px)",
          "title": "Max Width",
          "type": "integer"
        },
        "max_height": {
          "default": 99999,
          "description": "Downscale images taller than this (px)",
          "title": "Max Height",
          "type": "integer"
        },
        "filter": {
          "$ref": "#/$defs/ImageFilterConfig"
        },
        "stdout_persist": {
          "default": true,
          "description": "Save piped images to disk",
          "title": "Stdout Persist",
          "type": "boolean"
        },
        "stdout_persist_dir": {
          "default": "~/.markitai/assets",
          "description": "Directory for persisted piped images",
          "title": "Stdout Persist Dir",
          "type": "string"
        },
        "stdout_fetch_external": {
          "default": false,
          "description": "Download external image URLs from stdin",
          "title": "Stdout Fetch External",
          "type": "boolean"
        }
      },
      "title": "ImageConfig",
      "type": "object"
    },
    "ImageFilterConfig": {
      "description": "Image filter configuration.",
      "properties": {
        "min_width": {
          "default": 50,
          "description": "Skip images narrower than this (px)",
          "title": "Min Width",
          "type": "integer"
        },
        "min_height": {
          "default": 50,
          "description": "Skip images shorter than this (px)",
          "title": "Min Height",
          "type": "integer"
        },
        "min_area": {
          "default": 5000,
          "description": "Skip images smaller than this (px²)",
          "title": "Min Area",
          "type": "integer"
        },
        "deduplicate": {
          "default": true,
          "description": "Remove duplicate images by hash",
          "title": "Deduplicate",
          "type": "boolean"
        }
      },
      "title": "ImageFilterConfig",
      "type": "object"
    },
    "JinaConfig": {
      "description": "Jina Reader API configuration.",
      "properties": {
        "api_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Jina Reader API key (supports env: syntax)",
          "title": "Api Key"
        },
        "timeout": {
          "default": 30,
          "description": "Request timeout in seconds",
          "title": "Timeout",
          "type": "integer"
        },
        "rpm": {
          "default": 20,
          "description": "Max requests per minute",
          "minimum": 1,
          "title": "Rpm",
          "type": "integer"
        },
        "no_cache": {
          "default": false,
          "description": "Skip Jina server-side cache",
          "title": "No Cache",
          "type": "boolean"
        },
        "target_selector": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "CSS selector for content extraction",
          "title": "Target Selector"
        },
        "wait_for_selector": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Wait for element before extraction",
          "title": "Wait For Selector"
        }
      },
      "title": "JinaConfig",
      "type": "object"
    },
    "LLMConfig": {
      "description": "LLM configuration.",
      "properties": {
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        },
        "pure": {
          "default": false,
          "description": "Pure mode: raw MD sent directly to LLM, no markitai processing",
          "title": "Pure",
          "type": "boolean"
        },
        "keep_base": {
          "default": false,
          "description": "Keep base .md file alongside .llm.md in LLM mode",
          "title": "Keep Base",
          "type": "boolean"
        },
        "model_list": {
          "items": {
            "$ref": "#/$defs/ModelConfig"
          },
          "title": "Model List",
          "type": "array"
        },
        "providers": {
          "items": {
            "$ref": "#/$defs/LLMProviderConfig"
          },
          "title": "Providers",
          "type": "array"
        },
        "router_settings": {
          "$ref": "#/$defs/RouterSettings"
        },
        "concurrency": {
          "default": 10,
          "description": "Max parallel LLM requests",
          "minimum": 1,
          "title": "Concurrency",
          "type": "integer"
        }
      },
      "title": "LLMConfig",
      "type": "object"
    },
    "LLMProviderConfig": {
      "description": "Credentials for one provider connection, independent of its models.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "provider": {
          "title": "Provider",
          "type": "string"
        },
        "api_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Api Key"
        },
        "api_base": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Api Base"
        }
      },
      "required": [
        "id",
        "provider"
      ],
      "title": "LLMProviderConfig",
      "type": "object"
    },
    "LiteLLMParams": {
      "description": "LiteLLM parameters for a model.",
      "properties": {
        "model": {
          "title": "Model",
          "type": "string"
        },
        "api_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Api Key"
        },
        "api_base": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Custom API base URL to override the provider's default endpoint. Supports env:VAR_NAME syntax. Passed directly to LiteLLM; works with any LiteLLM-supported provider. Not used by local providers (claude-agent/, copilot/) which manage endpoints via their own environment variables.",
          "title": "Api Base"
        },
        "weight": {
          "default": 1,
          "description": "Routing weight for load balancing. 0 = disabled (model excluded from routing). Higher values get more traffic.",
          "minimum": 0,
          "title": "Weight",
          "type": "integer"
        },
        "max_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Tokens"
        }
      },
      "required": [
        "model"
      ],
      "title": "LiteLLMParams",
      "type": "object"
    },
    "LogConfig": {
      "description": "Logging configuration.",
      "properties": {
        "level": {
          "default": "INFO",
          "description": "Minimum log level",
          "enum": [
            "DEBUG",
            "INFO",
            "WARNING",
            "ERROR",
            "CRITICAL"
          ],
          "title": "Level",
          "type": "string"
        },
        "dir": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Log file directory",
          "title": "Dir"
        },
        "rotation": {
          "default": "10 MB",
          "description": "Rotate log file at this size",
          "title": "Rotation",
          "type": "string"
        },
        "retention": {
          "default": "7 days",
          "description": "Delete old logs after this period",
          "title": "Retention",
          "type": "string"
        },
        "format": {
          "default": "text",
          "description": "Log output format",
          "enum": [
            "text",
            "json"
          ],
          "title": "Format",
          "type": "string"
        }
      },
      "title": "LogConfig",
      "type": "object"
    },
    "ModelConfig": {
      "description": "Model configuration for LiteLLM Router.",
      "properties": {
        "model_name": {
          "title": "Model Name",
          "type": "string"
        },
        "litellm_params": {
          "$ref": "#/$defs/LiteLLMParams"
        },
        "model_info": {
          "anyOf": [
            {
              "$ref": "#/$defs/ModelInfo"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "model_name",
        "litellm_params"
      ],
      "title": "ModelConfig",
      "type": "object"
    },
    "ModelInfo": {
      "description": "Model metadata. All fields are optional and auto-detected from litellm if not set.",
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Id"
        },
        "provider_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Id"
        },
        "supports_vision": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Supports Vision"
        },
        "max_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Tokens"
        },
        "max_input_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Input Tokens"
        }
      },
      "title": "ModelInfo",
      "type": "object"
    },
    "OCRConfig": {
      "description": "OCR configuration.",
      "properties": {
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        },
        "lang": {
          "default": "en",
          "description": "OCR language code",
          "title": "Lang",
          "type": "string"
        },
        "per_page_routing": {
          "default": true,
          "description": "With --ocr, keep the native text layer for pages that do not look scanned/garbled and OCR only the remaining pages. Disable to OCR every page.",
          "title": "Per Page Routing",
          "type": "boolean"
        }
      },
      "title": "OCRConfig",
      "type": "object"
    },
    "OfficeConfig": {
      "description": "Office document conversion configuration.",
      "properties": {
        "macos_fallback": {
          "default": true,
          "description": "On macOS without LibreOffice, drive installed MS Office apps via AppleScript for legacy conversion and PPTX PDF export. Disable in headless sessions where macOS permission dialogs cannot be answered.",
          "title": "Macos Fallback",
          "type": "boolean"
        }
      },
