# Markitai environment variables / 环境变量配置
# Copy this file to .env and fill in your values / 复制此文件为 .env 并填入你的配置

# ============================================================
# LLM API keys (optional; not needed for ChatGPT OAuth or Claude/Copilot CLI providers)
# LLM API 密钥（可选；ChatGPT OAuth 或 Claude/Copilot CLI 提供商无需填写）
# ============================================================

# DeepSeek API
DEEPSEEK_API_KEY=

# Google Gemini API
GEMINI_API_KEY=

# OpenAI API
OPENAI_API_KEY=

# Anthropic API
ANTHROPIC_API_KEY=

# OpenRouter API: aggregates multiple providers
# OpenRouter API：聚合多个模型提供商
OPENROUTER_API_KEY=

# ============================================================
# Fetch services (optional) / 抓取服务（可选）
# ============================================================

# Jina Reader (https://jina.ai/reader)
JINA_API_KEY=

# Cloudflare: cloud URL rendering and file conversion
# Cloudflare：云端 URL 渲染和文件转换
# API Token: https://dash.cloudflare.com/profile/api-tokens
#   Create a Custom Token with: Browser Rendering: Edit + Workers AI: Read
#   创建 Custom Token，权限：Browser Rendering: Edit + Workers AI: Read
# Account ID: the ID in the Dashboard URL after login / 登录 Dashboard 后 URL 中的 ID
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ============================================================
# Markitai settings (optional) / Markitai 配置（可选）
# ============================================================

# Config file path (default: ./markitai.json or ~/.markitai/config.json)
# 配置文件路径，默认：./markitai.json 或 ~/.markitai/config.json
# MARKITAI_CONFIG=

# Log directory (default: ~/.markitai/logs) / 日志目录
# MARKITAI_LOG_DIR=

# Log format: text | json (default: text) / 日志格式
# MARKITAI_LOG_FORMAT=

# Language: zh | en (default: follows system LANG) / 语言（默认跟随系统）
# MARKITAI_LANG=

# Pure mode: skip frontmatter and other post-processing (same as --pure)
# With --llm enabled, raw Markdown is still sent to the configured LLM for text cleaning
# 纯模式：跳过 frontmatter 和其他后处理（等效于 --pure）
# 启用 --llm 时，原始 Markdown 仍会发送给已配置的 LLM 做文本清理
# MARKITAI_PURE=1

# Default model (same as --model)
# 默认模型，等效于 --model
# MODEL=

# Never send URLs to remote extraction services: defuddle.md, Jina, Cloudflare
# 禁止将 URL 发送给远程内容提取服务：defuddle.md、Jina、Cloudflare
# Any value except 0/false/no is a hard opt-out, including explicit -s remote strategies
# 除 0/false/no 外，任何值都会硬性禁用远程抓取，包括显式指定远程 -s 策略
# MARKITAI_NO_REMOTE_FETCH=1

# HTTP backend: httpx | curl_cffi (default: httpx) / HTTP 后端
# MARKITAI_STATIC_HTTP=
