# Markitai 环境变量配置
# 复制此文件为 .env 并填入你的配置

# ============================================================
# LLM API Keys (至少配置一个即可使用 --llm 功能)
# ============================================================

# DeepSeek API
DEEPSEEK_API_KEY=

# Google Gemini API
GEMINI_API_KEY=

# OpenAI API
OPENAI_API_KEY=

# Anthropic API
ANTHROPIC_API_KEY=

# OpenRouter API (聚合多个模型提供商)
OPENROUTER_API_KEY=

# ============================================================
# URL 抓取 (可选)
# ============================================================

# Jina Reader API (URL 转换策略之一)
JINA_API_KEY=

# Cloudflare (云端 URL 渲染和文件转换)
# API Token: https://dash.cloudflare.com/profile/api-tokens
#   创建 Custom Token，权限: Browser Rendering: Edit + Workers AI: Read
# Account ID: 登录 Dashboard 后 URL 中的 ID
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ============================================================
# Markitai 配置 (可选)
# ============================================================

# 配置文件路径 (默认: ./markitai.json 或 ~/.markitai/config.json)
# MARKITAI_CONFIG=

# 日志目录 (默认: ~/.markitai/logs)
# MARKITAI_LOG_DIR=

# 日志格式: text | json (默认: text)
# MARKITAI_LOG_FORMAT=

# 语言: zh | en (默认: 跟随系统 LANG)
# MARKITAI_LANG=

# 纯模式: 禁用所有 LLM 功能 (等效 --pure)
# MARKITAI_PURE=1

# 默认模型 (等效 --model)
# MODEL=

# HTTP 后端: httpx | curl_cffi (默认: httpx)
# MARKITAI_STATIC_HTTP=
